# Application
APP_NAME="AI Coding Mentor API"
ENVIRONMENT=development
APP_DEBUG=true
APP_SECRET_KEY=change-me-to-a-long-random-secret
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=30

# PostgreSQL / Redis (Docker Compose defaults)
DATABASE_URL=postgresql+asyncpg://mentor:mentor@localhost:5432/mentor
REDIS_URL=redis://localhost:6379/0

# Execution
PISTON_BASE_URL=http://localhost:2000
PISTON_REQUEST_TIMEOUT_SECONDS=15

# LLM provider selection. OpenAI is the default.
LLM_PROVIDER=openai
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile
HF_API_KEY=
HF_MODEL=meta-llama/Llama-3.3-70B-Instruct
LMSTUDIO_BASE_URL=http://host.docker.internal:1234/v1
LMSTUDIO_API_KEY=lm-studio
LMSTUDIO_MODEL=local-model

# OAuth applications (optional until Phase 2)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8000/auth/oauth/google/callback
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_REDIRECT_URI=http://localhost:8000/auth/oauth/github/callback
